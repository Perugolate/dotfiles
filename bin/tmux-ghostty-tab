#!/bin/sh
# Ghostty tab launcher (ghostty config: command = ~/.local/bin/tmux-ghostty-tab)
# First tab owns the persistent 'main' session (reattaching if it exists
# unattached, e.g. after quitting ghostty). Every further tab gets its own
# independent throwaway session, so tabs behave like plain terminal tabs:
# Ctrl-D/exit ends shell -> session -> tab; Cmd-W kills the tab's session
# (destroy-unattached). Only 'main' persists across closes.
TMUX_BIN=/opt/homebrew/bin/tmux

if "$TMUX_BIN" has-session -t main 2>/dev/null; then
  if [ -z "$("$TMUX_BIN" list-clients -t main 2>/dev/null)" ]; then
    exec "$TMUX_BIN" attach -t main
  fi
  # main is busy in another tab: ephemeral session for this one
  exec "$TMUX_BIN" new-session \; set-option destroy-unattached on
fi
exec "$TMUX_BIN" new-session -s main
