#!/bin/sh
# Ghostty tab launcher (ghostty config: command = ~/.local/bin/tmux-ghostty-tab)
# First tab creates the persistent session 'main'. Every further tab gets
# its own session GROUPED with main: windows are shared, focus is
# independent, so tabs don't mirror each other. Each extra tab opens a
# fresh window, and its session self-destructs on detach/close while
# 'main' (and all windows) persist.
TMUX_BIN=/opt/homebrew/bin/tmux
if "$TMUX_BIN" has-session -t main 2>/dev/null; then
  exec "$TMUX_BIN" new-session -t main \; set-option destroy-unattached on \; new-window
else
  exec "$TMUX_BIN" new-session -s main
fi
