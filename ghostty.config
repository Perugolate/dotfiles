# theme and fonts
font-family = "FiraCode Nerd Font Mono"
font-size = 14
#theme = catppuccin-mocha
theme = Catppuccin Mocha

# still unwanted blinking in R inside neovim
cursor-style = block
cursor-style-blink = false
selection-invert-fg-bg = true
cursor-color = f1e0dc
cursor-text = 1e1d2c
shell-integration = zsh
shell-integration-features = no-cursor

# every ghostty surface runs the tab launcher: first tab creates the
# persistent 'main' session, further tabs get grouped sessions (shared
# windows, independent focus) so tabs don't mirror. Nvim :terminal shells
# are unaffected. Closing a tab detaches/destroys only its grouped
# session; 'main' survives.
command = /Users/paul/.local/bin/tmux-ghostty-tab

# hot-key to open/focus quick terminal
#keybind = global:f12=toggle_quick_terminal
# F12 toggle now handled by hammerspoon (~/.hammerspoon/init.lua), which
# restores focus to the previous app correctly (macOS 15.7 hands focus
# to Finder when ghostty hides itself)
#keybind = global:f12=toggle_visibility

# tabs is the least ugly option
macos-titlebar-style = tabs
window-height = 50
window-width = 177

# remap left option key as Alt
macos-option-as-alt = left
keybind = alt+left=unbind
keybind = alt+right=unbind

# set to clipboard rather than true
copy-on-select = clipboard

mouse-hide-while-typing = true

window-inherit-working-directory = false
tab-inherit-working-directory = false

# vim-style scrollback navigation via key tables
# (ghostty-org/ghostty discussion #3708). Enter with alt+v; leave with
# escape or q. shift+hjkl adjusts a keyboard selection (copy-on-select
# puts it on the clipboard); y copies explicitly.
keybind = alt+v=activate_key_table:vim
keybind = vim/j=scroll_page_lines:1
keybind = vim/k=scroll_page_lines:-1
keybind = vim/ctrl+d=scroll_page_fractional:0.5
keybind = vim/ctrl+u=scroll_page_fractional:-0.5
keybind = vim/g>g=scroll_to_top
keybind = vim/shift+g=scroll_to_bottom
keybind = vim/shift+h=adjust_selection:left
keybind = vim/shift+j=adjust_selection:down
keybind = vim/shift+k=adjust_selection:up
keybind = vim/shift+l=adjust_selection:right
keybind = vim/y=copy_to_clipboard
keybind = vim/escape=deactivate_key_table
keybind = vim/q=deactivate_key_table
# swallow all other keys while the table is active so stray presses
# don't leak through to the shell prompt
keybind = vim/catch_all=ignore
